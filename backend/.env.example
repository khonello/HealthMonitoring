SECRET_KEY=your-django-secret-key-here
DEBUG=True

# Database (PostgreSQL — production only, SQLite is used in development)
DB_NAME=healthmonitoring
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Groq
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Django settings module
DJANGO_SETTINGS_MODULE=configs.settings.development

# CORS (comma-separated, production only)
CORS_ALLOWED_ORIGINS=http://localhost:8081

# Allowed hosts (comma-separated, production only)
ALLOWED_HOSTS=localhost,127.0.0.1
